+// Dynamic group member name cache: chatId -> { open_id -> name }
+const groupMemberNameCache = new Map();
+const GROUP_MEMBER_CACHE_TTL_MS = 60 * 60 * 1000; // 1 hour
+// Fetch and cache group members for a chat
+async function fetchGroupMembers(params) {
+	const { client, chatId, log } = params;
+	const cached = groupMemberNameCache.get(chatId);
+	const now = Date.now();
+	if (cached && cached.expireAt > now) {
+		return cached.members;
+	}
+	try {
+		const members = new Map();
+		let pageToken;
+		do {
+			const response = await client.im.chatMembers.get({
+				path: { chat_id: chatId },
+				params: { member_id_type: "open_id", page_size: 100, page_token: pageToken }
+			});
+			const items = response.data?.items ?? [];
+			for (const item of items) {
+				if (item.member_id && item.name) {
+					members.set(item.member_id, item.name);
+				}
+			}
+			pageToken = response.data?.page_token;
+		} while (pageToken);
+		groupMemberNameCache.set(chatId, { members, expireAt: now + GROUP_MEMBER_CACHE_TTL_MS });
+		log(`feishu: cached ${members.size} members for chat ${chatId}`);
+		return members;
+	} catch (err) {
+		log(`feishu: failed to fetch members for chat ${chatId}: ${String(err)}`);
+		return cached?.members ?? new Map();
+	}
+}
+// Find sender name from group member cache
+function findSenderNameInGroupCache(senderId, chatId) {
+	const cached = groupMemberNameCache.get(chatId);
+	if (cached?.members) {
+		return cached.members.get(senderId);
+	}
+	return undefined;
+}
